# ==============================
# App Settings
# ==============================
APP_NAME=ecommerce-multiagent-rag
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# ==============================
# LLM Provider Selection
# Pilihan: huggingface | openai | claude | gemini | deepseek | qwen | mistral | ollama
# ==============================
LLM_PROVIDER=huggingface
LLM_MODEL_NAME=meta-llama/Llama-3.2-3B-Instruct
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ==============================
# HuggingFace
# ==============================
HUGGINGFACE_API_TOKEN=

# ==============================
# OpenAI
# ==============================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ==============================
# Anthropic Claude
# ==============================
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ==============================
# Google Gemini
# ==============================
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ==============================
# DeepSeek
# ==============================
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==============================
# Qwen
# ==============================
QWEN_API_KEY=
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==============================
# Mistral
# ==============================
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# ==============================
# Ollama (Local)
# ==============================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ==============================
# Embedding Model
# ==============================
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ==============================
# ChromaDB
# ==============================
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_FINANCE_COLLECTION=finance_collection
CHROMA_LOGISTICS_COLLECTION=logistics_collection
CHROMA_QA_COLLECTION=qa_collection

# ==============================
# Dataset Paths
# ==============================
DATASET_DIR=./data/raw
DATASET_ORDERS=orders.csv
DATASET_ORDER_ITEMS=order_items.csv
DATASET_ORDER_PAYMENTS=order_payments.csv
DATASET_PRODUCTS=products.csv
DATASET_ORDER_REVIEWS=order_reviews.csv
DATASET_SELLERS=sellers.csv

# ==============================
# API Server
# ==============================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=*

# ==============================
# Evaluation
# ==============================
EVAL_SAMPLE_SIZE=25
EVAL_REPORT_DIR=./data/evaluation_reports
