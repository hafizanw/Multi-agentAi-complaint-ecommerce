# Pilih provider: "ollama" (gratis/lokal), "openai", atau "anthropic"
LLM_PROVIDER=ollama

# Kalau pakai Ollama (default, gratis)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b

# Kalau pakai OpenAI (berbayar)
OPENAI_API_KEY=

# Kalau pakai Anthropic (berbayar)
ANTHROPIC_API_KEY=

# Jumlah sample data per divisi untuk build vectorstore (kosongkan/None untuk pakai semua data)
SAMPLE_SIZE=8000
